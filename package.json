{
  "name": "kage-extensions",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Catalog of Kage extensions and themes",
  "scripts": {
    "build": "node scripts/build-catalog.mjs",
    "validate": "node scripts/validate-manifests.mjs",
    "check:permissions": "node scripts/check-permissions.mjs",
    "check:security": "node scripts/check-security.mjs",
    "check:i18n": "node scripts/check-i18n.mjs",
    "check:bundle": "node scripts/check-bundle.mjs",
    "check:host-sync": "node scripts/check-host-sync.mjs",
    "check:tests": "node scripts/check-tests.mjs",
    "check:versions": "node scripts/check-versions.mjs",
    "check:all": "npm run validate && npm run check:permissions && npm run check:security && npm run check:i18n && npm run check:bundle && npm run check:tests && npm run check:versions",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "archiver": "^7.0.1",
    "jsdom": "^29.1.1",
    "mathjs": "^15.2.0",
    "vitest": "^4.1.8"
  }
}

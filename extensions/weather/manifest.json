{
  "id": "weather",
  "name": "__MSG_manifest.name__",
  "version": "1.0.0",
  "type": "extension",
  "description": "__MSG_manifest.description__",
  "icon": "🌤️",
  "author": "kage",
  "tags": [
    "weather",
    "forecast",
    "temperature",
    "open-meteo"
  ],
  "permissions": [
    "storage"
  ],
  "config": {
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "trigger": {
      "type": "string",
      "default": "weather"
    },
    "home_location": {
      "type": "string",
      "default": ""
    },
    "units": {
      "type": "string",
      "default": "metric"
    }
  },
  "contributes": {
    "searchProvider": "./search.js",
    "settingsProvider": "./settings.js"
  }
}

{
  "id": "currency",
  "name": "__MSG_manifest.name__",
  "version": "1.0.0",
  "type": "extension",
  "description": "__MSG_manifest.description__",
  "icon": "💱",
  "author": "kage",
  "tags": [
    "currency",
    "money",
    "fx",
    "exchange",
    "convert",
    "finance"
  ],
  "permissions": [
    "storage"
  ],
  "config": {
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "default_source": {
      "type": "string",
      "default": "USD"
    },
    "default_target": {
      "type": "string",
      "default": "EUR"
    }
  },
  "contributes": {
    "searchProvider": "./search.js",
    "settingsProvider": "./settings.js"
  }
}

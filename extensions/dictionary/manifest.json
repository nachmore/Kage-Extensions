{
  "id": "dictionary",
  "name": "__MSG_manifest.name__",
  "version": "1.7.4",
  "type": "extension",
  "description": "__MSG_manifest.description__",
  "icon": "📖",
  "author": "kage",
  "permissions": [],
  "config": {
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "trigger": {
      "type": "string",
      "default": "dict"
    },
    "language": {
      "type": "string",
      "default": "auto"
    },
    "show_pronunciation": {
      "type": "boolean",
      "default": true
    },
    "show_examples": {
      "type": "boolean",
      "default": true
    },
    "show_synonyms": {
      "type": "boolean",
      "default": true
    }
  },
  "contributes": {
    "searchProvider": "./search.js",
    "settingsProvider": "./settings.js",
    "css": [
      "./styles.css"
    ]
  },
  "tags": [
    "dictionary",
    "spelling",
    "definitions",
    "language",
    "words",
    "translate"
  ]
}

{
  "id": "password",
  "name": "__MSG_manifest.name__",
  "version": "1.0.0",
  "type": "extension",
  "description": "__MSG_manifest.description__",
  "icon": "🔐",
  "author": "kage",
  "tags": [
    "password",
    "passphrase",
    "random",
    "security",
    "generator"
  ],
  "permissions": [],
  "config": {
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "trigger": {
      "type": "string",
      "default": "pw"
    },
    "default_length": {
      "type": "number",
      "default": 20
    },
    "include_symbols": {
      "type": "boolean",
      "default": true
    },
    "include_numbers": {
      "type": "boolean",
      "default": true
    },
    "include_lowercase": {
      "type": "boolean",
      "default": true
    },
    "include_uppercase": {
      "type": "boolean",
      "default": true
    },
    "exclude_ambiguous": {
      "type": "boolean",
      "default": true
    }
  },
  "contributes": {
    "searchProvider": "./search.js",
    "settingsProvider": "./settings.js"
  }
}

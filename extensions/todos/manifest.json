{
  "id": "todos",
  "name": "__MSG_manifest.name__",
  "version": "1.0.3",
  "type": "extension",
  "description": "__MSG_manifest.description__",
  "icon": "✅",
  "author": "kage",
  "permissions": [
    "storage",
    "automation"
  ],
  "config": {
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "default_category": {
      "type": "string",
      "default": ""
    },
    "show_completed": {
      "type": "boolean",
      "default": true
    },
    "confirm_delete": {
      "type": "boolean",
      "default": true
    },
    "sort_by": {
      "type": "string",
      "default": "created"
    },
    "show_due_banner": {
      "type": "boolean",
      "default": true
    }
  },
  "contributes": {
    "searchProvider": "./search.js",
    "settingsProvider": "./settings.js",
    "toolbarButtons": "./toolbar.js",
    "triggerProvider": "./triggers.js",
    "widgets": [
      {
        "id": "due-reminder",
        "slot": "floating-bottom",
        "module": "./widget.js"
      }
    ],
    "css": [
      "./styles.css"
    ]
  },
  "tags": [
    "productivity",
    "tasks",
    "todo",
    "organizer",
    "reminders"
  ]
}

{
  "id": "snippets",
  "name": "Snippets",
  "version": "1.0.0",
  "type": "extension",
  "description": "Saved text snippets, copyable from the launcher. Perfect for canned responses, addresses, GIT commands, anything you type often.",
  "icon": "📋",
  "author": "kage",
  "tags": ["snippets", "clipboard", "templates", "canned-text", "productivity"],

  "permissions": ["storage"],

  "config": {
    "enabled": { "type": "boolean", "default": true },
    "trigger": { "type": "string", "default": "snip" }
  },

  "contributes": {
    "searchProvider": "./search.js",
    "settingsProvider": "./settings.js"
  }
}

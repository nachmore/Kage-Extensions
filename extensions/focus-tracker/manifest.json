{
  "id": "focus-tracker",
  "name": "__MSG_manifest.name__",
  "version": "1.7.0",
  "type": "extension",
  "description": "__MSG_manifest.description__",
  "icon": "📊",
  "author": "kage",
  "permissions": [
    "activity",
    "windows"
  ],
  "config": {
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "trigger": {
      "type": "string",
      "default": "focus"
    },
    "poll_interval": {
      "type": "number",
      "default": 5
    },
    "track_screen_time": {
      "type": "boolean",
      "default": true
    },
    "track_switches": {
      "type": "boolean",
      "default": true
    },
    "track_streaks": {
      "type": "boolean",
      "default": true
    }
  },
  "contributes": {
    "searchProvider": "./search.js",
    "settingsProvider": "./settings.js"
  },
  "tags": [
    "focus",
    "productivity",
    "screen time",
    "activity",
    "tracker",
    "heatmap"
  ]
}

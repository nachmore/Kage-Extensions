{
  "id": "focus-tracker",
  "name": "Focus Tracker",
  "version": "1.3.2",
  "type": "extension",
  "description": "Track app usage, context switches, and focus streaks. Get daily/weekly/monthly reports with AI insights.",
  "icon": "📊",
  "author": "kage",
  "permissions": [
    "activity"
  ],
  "config": {
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "trigger": {
      "type": "string",
      "default": "focus"
    },
    "poll_interval": {
      "type": "number",
      "default": 5
    },
    "auto_start": {
      "type": "boolean",
      "default": true
    },
    "track_screen_time": {
      "type": "boolean",
      "default": true
    },
    "track_switches": {
      "type": "boolean",
      "default": true
    },
    "track_streaks": {
      "type": "boolean",
      "default": true
    }
  },
  "contributes": {
    "searchProvider": "./search.js",
    "settingsProvider": "./settings.js",
    "css": [
      "./styles.css"
    ]
  },
  "tags": [
    "focus",
    "productivity",
    "screen time",
    "activity",
    "tracker",
    "heatmap"
  ]
}

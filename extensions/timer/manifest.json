{
  "id": "timer",
  "name": "__MSG_manifest.name__",
  "version": "1.0.0",
  "type": "extension",
  "description": "__MSG_manifest.description__",
  "icon": "⏱️",
  "author": "kage",
  "permissions": [],
  "config": {
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "notify_on_complete": {
      "type": "boolean",
      "default": true
    },
    "sound_on_complete": {
      "type": "boolean",
      "default": true
    },
    "sound_id": {
      "type": "string",
      "default": "two-tone"
    },
    "custom_sound_path": {
      "type": "string",
      "default": ""
    },
    "sound_repeats": {
      "type": "number",
      "default": 3
    },
    "show_window_on_complete": {
      "type": "boolean",
      "default": true
    }
  },
  "contributes": {
    "searchProvider": "./search.js",
    "settingsProvider": "./settings.js"
  },
  "tags": [
    "timer",
    "stopwatch",
    "productivity",
    "pomodoro"
  ]
}

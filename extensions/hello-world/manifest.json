{
  "id": "hello-world",
  "name": "Hello World",
  "version": "1.0.0",
  "type": "extension",
  "description": "A sample extension that responds to 'test' with 'Hello World'. Use this as a template for building your own extensions.",
  "icon": "👋",
  "author": "kage",
  "permissions": [],
  "config": {
    "greeting": {
      "type": "string",
      "default": "Hello World"
    },
    "show_timestamp": {
      "type": "boolean",
      "default": false
    }
  },
  "contributes": {
    "searchProvider": "./search.js",
    "settingsProvider": "./settings.js"
  },
  "tags": [
    "sample",
    "template",
    "starter"
  ]
}

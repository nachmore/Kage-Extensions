{
  "id": "spotify",
  "name": "Spotify",
  "version": "0.1.0",
  "type": "extension",
  "description": "See what's playing on Spotify, control playback, like / unlike, queue, and manage playlists from Kage.",
  "icon": "🎧",
  "author": "kage",
  "tags": ["music", "spotify", "playback", "audio", "now-playing", "playlist"],

  "permissions": ["storage", "shell", "oauth"],

  "config": {
    "enabled": { "type": "boolean", "default": true },
    "show_now_playing_bar": { "type": "boolean", "default": true },
    "refresh_seconds": { "type": "number", "default": 5 },
    "trigger": { "type": "string", "default": "sp" }
  },

  "contributes": {
    "searchProvider": "./search.js",
    "settingsProvider": "./settings.js",
    "toolProvider": "./tools.js",
    "css": ["./styles.css"],
    "widgets": [
      {
        "id": "now-playing",
        "slot": "floating-bottom",
        "module": "./widget.js"
      }
    ]
  }
}

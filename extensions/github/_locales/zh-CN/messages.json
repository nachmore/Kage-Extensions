  },
  "settings.access.intro_html": {
    "message": "<p>请在 <a href=\"https://github.com/settings/personal-access-tokens/new\">github.com/settings/personal-access-tokens/new</a> 生成细粒度个人访问令牌。对要搜索的仓库 / 议题 / 用户具有<em>只读</em>权限即可。令牌不会离开你的设备，仅会在 Authorization 标头中发送至 <code>api.github.com</code>。</p>",
    "description": "Intro html in settings",
    "_machine_translated": true,

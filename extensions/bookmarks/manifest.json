{
  "id": "bookmarks",
  "name": "Bookmarks",
  "version": "1.0.0",
  "type": "extension",
  "description": "Save and open URLs from Kage's launcher. Type \"bm <name>\" to open, \"bm+ <name> <url>\" to save, \"bm- <name>\" to delete.",
  "icon": "🔖",
  "author": "kage",
  "tags": ["bookmarks", "urls", "links", "shortcuts", "launcher"],

  "permissions": ["storage", "shell"],

  "config": {
    "enabled": { "type": "boolean", "default": true },
    "trigger": { "type": "string", "default": "bm" }
  },

  "contributes": {
    "searchProvider": "./search.js",
    "settingsProvider": "./settings.js"
  }
}

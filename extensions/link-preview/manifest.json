{
  "id": "link-preview",
  "name": "Link Preview",
  "version": "1.2.0",
  "type": "extension",
  "description": "Rich link preview cards for URLs in AI responses — Open Graph hero images, descriptions, and favicons, with offline-friendly disk caching.",
  "icon": "🔗",
  "author": "kage",
  "permissions": [
    "network"
  ],
  "config": {
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "max_previews": {
      "type": "number",
      "default": 5
    },
    "show_images": {
      "type": "boolean",
      "default": true
    }
  },
  "contributes": {
    "messageFormatters": "./formatter.js",
    "settingsProvider": "./settings.js",
    "css": [
      "./styles.css"
    ]
  },
  "tags": [
    "utility",
    "formatting",
    "links"
  ]
}

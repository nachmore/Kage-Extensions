{
  "id": "dev-tools",
  "name": "Developer Tools",
  "version": "1.0.0",
  "type": "extension",
  "description": "UUID generation, base64 encode/decode, hashing, epoch conversion, JSON formatting",
  "icon": "🔧",
  "author": "kage",
  "permissions": [],
  "config": {
    "enabled": {
      "type": "boolean",
      "default": true
    },
    "uuid": {
      "type": "boolean",
      "default": true
    },
    "base64": {
      "type": "boolean",
      "default": true
    },
    "hash": {
      "type": "boolean",
      "default": true
    },
    "epoch": {
      "type": "boolean",
      "default": true
    },
    "json_format": {
      "type": "boolean",
      "default": true
    }
  },
  "contributes": {
    "searchProvider": "./search.js",
    "settingsProvider": "./settings.js"
  },
  "tags": [
    "developer",
    "uuid",
    "base64",
    "hash",
    "json",
    "utility"
  ]
}

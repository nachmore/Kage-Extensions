{
  "id": "emoji",
  "name": "Emoji Picker",
  "version": "1.0.0",
  "type": "extension",
  "description": "Search and copy emojis by name. Type \":fire\" or \"emoji rocket\" — picks the closest match across ~1500 of the most-used emojis.",
  "icon": "😀",
  "author": "kage",
  "tags": ["emoji", "picker", "unicode", "smiley", "react"],

  "permissions": [],

  "config": {
    "enabled": { "type": "boolean", "default": true },
    "trigger": { "type": "string", "default": "emoji" },
    "shortcode_trigger": { "type": "boolean", "default": true }
  },

  "contributes": {
    "searchProvider": "./search.js",
    "settingsProvider": "./settings.js"
  }
}
